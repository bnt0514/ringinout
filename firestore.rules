rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null
          && request.auth.uid == 'IPf2TW0c62et7bwi8B5hZGyKLlc2';
    }

    // ── 지도 사용량: 부모 문서는 어드민만 쓸 수 있음, 기기별 서브컬렉션은 본인만
    match /map_usage/{month} {
      allow read: if isAdmin();
      allow write: if isAdmin();

      // 기기별 서브컬렉션 — 본인 문서만 쓰기 가능
      match /devices/{uid} {
        allow read: if isAdmin();
        allow write: if isAuthenticated() && request.auth.uid == uid;
      }
    }

    match /map_usage_weekly/{week} {
      allow read: if isAdmin();
      allow write: if isAdmin();

      match /devices/{uid} {
        allow read: if isAdmin();
        allow write: if isAuthenticated() && request.auth.uid == uid;
      }
    }

    // ── 어드민 설정: 읽기는 인증된 유저, 쓰기는 어드민만
    match /admin_config/{doc} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── 사용자 데이터: 본인 것만
    match /users/{userId} {
      allow read, write: if request.auth != null
          && request.auth.uid == userId;
    }

    // ── 구독 정보: 읽기만 본인 허용, 쓰기는 Cloud Functions 전용
    match /subscriptions/{userId} {
      allow read: if request.auth != null
          && request.auth.uid == userId;
      allow write: if false;
    }

    // ── 버그 리포트: 쓰기는 인증된 모든 유저, 읽기는 어드민만
    match /bug_reports/{reportId} {
      allow read: if isAdmin();
      allow write: if isAuthenticated();
    }

    // ── Cloud Functions 내부 컬렉션: 서버(Admin SDK)만 접근, 클라이언트 차단
    match /cf_users/{docId} {
      allow read, write: if false;
    }
    match /cf_subscriptions/{docId} {
      allow read, write: if false;
    }
  }
}
