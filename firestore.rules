rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null
          && request.auth.uid == 'IPf2TW0c62et7bwi8B5hZGyKLlc2';
    }

    // ── 지도 사용량: 클라이언트 직접 쓰기 차단, Cloud Functions 전용
    match /map_usage/{month} {
      allow read: if isAdmin();
      allow write: if isAdmin();

      match /devices/{uid} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }

    match /map_usage_weekly/{week} {
      allow read: if isAdmin();
      allow write: if isAdmin();

      match /devices/{uid} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }

    // ── 어드민 설정: 읽기는 인증된 유저, 쓰기는 어드민만
    match /admin_config/{doc} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── 사용자 데이터: parent doc은 플랜 조작 방지를 위해 클라이언트 직접 쓰기 차단
    match /users/{userId} {
      allow read, delete: if isAdmin()
          || (request.auth != null && request.auth.uid == userId);
      allow create, update: if isAdmin();

      match /agreements/{agreementId} {
        allow read: if isAdmin()
            || (request.auth != null && request.auth.uid == userId);
        allow create, update: if request.auth != null
            && request.auth.uid == userId
            && agreementId == 'terms'
            && request.resource.data.keys().hasOnly(['version', 'agreedAt'])
            && request.resource.data.version is string;
        allow delete: if isAdmin()
            || (request.auth != null && request.auth.uid == userId);
      }
    }

    // ── 구독 정보: 읽기만 본인 허용, 쓰기는 Cloud Functions 전용
    match /subscriptions/{userId} {
      allow read: if request.auth != null
          && request.auth.uid == userId;
      allow write: if false;
    }

    // ── 버그 리포트: 클라이언트 직접 쓰기 차단, Cloud Functions 전용
    match /bug_reports/{reportId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Cloud Functions 내부 컬렉션: 서버(Admin SDK)만 접근, 클라이언트 차단
    match /cf_users/{docId} {
      allow read, write: if false;
    }
    match /cf_subscriptions/{docId} {
      allow read, write: if false;
    }
    match /purchase_tokens/{docId} {
      allow read, write: if false;
    }
    match /rate_limits/{docId} {
      allow read, write: if false;
    }
    match /ops_alerts/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /ops_reports/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── 쿼터 (월간 검색/알람 사용량): 본인 읽기 + 제한적 쓰기, 어드민 전체 가시
    //    경로: quotas/{uid}/months/{yyyy-MM}
    //    필드: search_used, search_reward, alarm_used, alarm_reward,
    //          plan_snapshot, uid, last_updated
    match /quotas/{uid} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);
      allow write: if false; // 부모 문서는 사용 안 함

      match /months/{month} {
        allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);
        // Cloud Functions incrementQuota 전용
        allow create, update, delete: if false;
      }
    }

    // ── 글로벌 풀 (월간 전사 합계): Cloud Functions incrementQuota 전용
    //    경로: pools/{yyyy-MM}
    //    필드: search_total, alarm_total, last_updated
    match /pools/{month} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
  }
}
